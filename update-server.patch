+// Endpoint to get all exercises
+app.get('/api/exercises', async (req, res) => {
+    try {
+        const result = await pool.query('SELECT * FROM Exercises ORDER BY name ASC');
+        res.json(result.rows);
+    } catch (err) {
+        res.status(500).json({ error: String(err) });
+    }
+});
+
+// Endpoint to log a workout
+app.post('/api/workouts', async (req, res) => {
+    const client = await pool.connect();
+    try {
+        await client.query('BEGIN');
+        
+        const { notes, exercises } = req.body;
+        
+        // 1. Get first user or create guest user if none exists
+        let userRes = await client.query('SELECT id FROM Users LIMIT 1');
+        let userId;
+        if (userRes.rows.length === 0) {
+            userId = uuidv4();
+            await client.query("INSERT INTO Users (id, name) VALUES ($1, 'Guest')", [userId]);
+        } else {
+            userId = userRes.rows[0].id;
+        }
+
+        // 2. Insert Workout
+        const workoutId = uuidv4();
+        await client.query(
+            'INSERT INTO Workouts (id, user_id, date, notes) VALUES ($1, $2, CURRENT_DATE, $3)',
+            [workoutId, userId, notes || '']
+        );
+
+        // 3. Insert Exercises & Sets
+        for (const ex of exercises) {
+            const workoutExerciseId = uuidv4();
+            await client.query(
+                'INSERT INTO WorkoutExercises (id, workout_id, exercise_id) VALUES ($1, $2, $3)',
+                [workoutExerciseId, workoutId, ex.exerciseId]
+            );
+            
+            let setNum = 1;
+            for (const s of ex.sets) {
+                await client.query(
+                    'INSERT INTO WorkoutSets (id, workout_exercise_id, set_number, reps, weight) VALUES ($1, $2, $3, $4, $5)',
+                    [uuidv4(), workoutExerciseId, setNum++, s.reps, s.weight]
+                );
+            }
+        }
+
+        await client.query('COMMIT');
+        res.status(201).json({ message: 'Workout saved successfully', id: workoutId });
+    } catch (err) {
+        await client.query('ROLLBACK');
+        res.status(500).json({ error: String(err) });
+    } finally {
+        client.release();
+    }
+});
+
